void HAL_I2SEx_TxRxHalfCpltCallback(I2S_HandleTypeDef *hi2s3){
	pBufIn = &adcData[0];
	pBufOut = &dacData[0];
	ready = 1;
}

void HAL_I2SEx_TxRxCpltCallback(I2S_HandleTypeDef *hi2s3){
	pBufIn = &adcData[BUFFER_SIZE / 2];
	pBufOut = &dacData[BUFFER_SIZE / 2];
	ready = 1;

}

void processData(){

    static float RightIn; // device is mono input
    static float RightOut, LeftOut;

    for(uint16_t i = 0; i < (BUFFER_SIZE / 2) - 1; i += 2){
  	  int32_t rawR = pBufIn[i + 1] >> 8;
  	  RightIn = rawR * INT24_TO_FLOAT;

  	  // add routing algorithm for effects
  	  RightOut = DSP_IIR_LPF_Update(&LPF, RightIn);
  	  LeftOut  = RightIn;

  	  // clipping range
        if (LeftOut  >  1.0f) LeftOut  =  1.0f;
        if (LeftOut  < -1.0f) LeftOut  = -1.0f;
        if (RightOut >  1.0f) RightOut =  1.0f;
        if (RightOut < -1.0f) RightOut = -1.0f;

        int32_t outL = (int32_t)(LeftOut  * FLOAT_TO_INT24);
        int32_t outR = (int32_t)(RightOut * FLOAT_TO_INT24);

        pBufOut[i]     = outL << 8;
        pBufOut[i + 1] = outR << 8;
    }
    ready = 0;

}

void DSP_IIR_LPF_Init(DSP_LPF *filter){
	 filter -> cBi[0] = 1.0f;
	 filter -> cBi[1] = 0.0f;

	 filter -> PrevIn = 0.0f;
	 filter -> BiOut = 0.0f;
}

// call on change of parameter
void DSP_IIR_LPF_SetCoeff(DSP_LPF *filter, float CutoffFreq, float SampleFreq){
	// normalized pre-warp Fc
	float wcT = 2.0f * tanf(M_PI * CutoffFreq / SampleFreq);

	// calculate coefficients
	filter -> cBi[0] = wcT / (wcT + 2.0f);
	filter -> cBi[1] = (2.0f - wcT) / (wcT + 2.0f);


}

// call in DSP pipeline
float DSP_IIR_LPF_Update(DSP_LPF *filter, float input){
	float a = filter -> cBi[0];
	float b = filter -> cBi[1];

	filter -> BiOut = a * (input + filter -> PrevIn) + b * filter -> BiOut;
	filter -> PrevIn = input;

	return filter -> BiOut;
}

