#include "DSP/DSP_Shifter.h"
#include <math.h>
#include <string.h>

void DSP_Shifter_Init(DSP_Shifter *s, float semitones)
{
    memset(s, 0, sizeof(*s));

    s->pitch_ratio = powf(2.0f, semitones / 12.0f);

    for (int i = 0; i < SHIFTER_WIN; i++) {
        s->window[i] =
            0.5f - 0.5f * cosf(2.0f * M_PI * i / (SHIFTER_WIN - 1));
    }
}

float DSP_Shifter_Update(DSP_Shifter *s, float in)
{
    /* ---------- input buffer ---------- */
    if (s->inFill < SHIFTER_WIN) {
        s->inBuf[s->inFill++] = in;
    }

    /* ---------- output read ---------- */
    float out = 0.0f;
    float norm = s->normBuf[s->outReadIdx];

    if (norm > 1e-6f) {
        out = s->outBuf[s->outReadIdx] / norm;
    }

    s->outBuf[s->outReadIdx]  = 0.0f;
    s->normBuf[s->outReadIdx] = 0.0f;
    s->outReadIdx = (s->outReadIdx + 1) % SHIFTER_OUTBUF;

    s->hopCtr++;

    /* ---------- process frame ---------- */
    if (s->inFill == SHIFTER_WIN && s->hopCtr >= SHIFTER_HOP) {
        s->hopCtr = 0;

        float readPos = 0.0f;

        for (int i = 0; i < SHIFTER_WIN; i++) {

            int idx = (int)readPos;
            float frac = readPos - idx;

            if (idx > SHIFTER_WIN - 2)
                break;

            float sample =
                s->inBuf[idx] * (1.0f - frac) +
                s->inBuf[idx + 1] * frac;

            uint16_t outIdx =
                (s->outWriteIdx + i) % SHIFTER_OUTBUF;

            float w = s->window[i];
            s->outBuf[outIdx]  += sample * w;
            s->normBuf[outIdx] += w * w;

            readPos += s->pitch_ratio;
        }

        /* ---------- shift input buffer ---------- */
        memmove(
            s->inBuf,
            s->inBuf + SHIFTER_HOP,
            (SHIFTER_WIN - SHIFTER_HOP) * sizeof(float)
        );
        s->inFill = SHIFTER_WIN - SHIFTER_HOP;

        /* ---------- FIXED synthesis hop ---------- */
        s->outWriteIdx =
            (s->outWriteIdx + SHIFTER_HOP) % SHIFTER_OUTBUF;
    }

    /* ---------- safety clamp ---------- */
    if (out >  1.0f) out =  1.0f;
    if (out < -1.0f) out = -1.0f;

    return out;
}
