#include "DSP/DSP_IIR_LPF.h"

// IIR low-pass filter module of simple RC filter
// Based off Phil's Lab #159 lesson video

void DSP_IIR_LPF_Init(DSP_LPF *filter){
	 filter -> cBi[0] = 1.0f;
	 filter -> cBi[1] = 0.0f;

	 filter -> cBEul[0] = 1.0f;
	 filter -> cBEul[1] = 0.0f;

	 filter -> PrevIn = 1.0f;
	 filter -> BiOut = 1.0f;
	 filter -> BEulOut = 1.0f;
}

