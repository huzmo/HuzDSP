#ifndef INC_DSP_DSP_SHIFTER_H_
#define INC_DSP_DSP_SHIFTER_H_

#include <stdint.h>
#include <math.h>

typedef struct {
	uint16_t win_len;  // sample window length
	uint16_t hop_len;  // distance between start of samples

	float    pitch_ratio;

	uint16_t synthWin_len;
	uint16_t synthHop_len;

	float windowf; // Hanning function

	float window[256];
	float inBuf[256];
	float outBuf[256];

	uint16_t inIdx;
	uint16_t outIdx;
	uint16_t hopCtr;

} DSP_Shifter;

void DSP_Shifter_Init(DSP_Shifter *shifter,
					  float        semitones);

void DSP_Shifter_Update(DSP_Shifter *shifter,
						float        input);


#endif /* INC_DSP_DSP_SHIFTER_H_ */
