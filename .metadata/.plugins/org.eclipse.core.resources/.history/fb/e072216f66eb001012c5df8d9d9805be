#include "DSP/DSP_IIR_HPF.h"
#include "string.h"

void DSP_HPF_Init(DSP_HPF *f)
{
    f->b[0] =  1.0f;
    f->b[1] = -2.0f;
    f->b[2] =  1.0f;

    // IMPORTANT: a1, a2 ONLY
    f->a[0] = -1.9444021537341245f;  // a1
    f->a[1] =  0.9459064615860119f;  // a2

    f->gain = 1.0281960624532192f;

    memset(f->x, 0, sizeof(f->x));
    memset(f->y, 0, sizeof(f->y));
}

float DSP_HPF_Update(DSP_HPF *f, float in)
{
    f->x[0] = f->x[1];
    f->x[1] = f->x[2];
    f->x[2] = in / f->gain;

    f->y[0] = f->y[1];
    f->y[1] = f->y[2];

    float out =
        f->b[0] * f->x[2] +
        f->b[1] * f->x[1] +
        f->b[2] * f->x[0] -
        f->a[0] * f->y[1] -
        f->a[1] * f->y[0];

    f->y[2] = out;
    return out;
}


