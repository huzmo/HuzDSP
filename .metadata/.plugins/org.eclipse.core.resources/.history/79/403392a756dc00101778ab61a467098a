// IIR low-pass filter module of simple RC filter
// Based off Phil's Lab #159 lecture video

void DSP_IIR_LPF_Init(DSP_LPF *filter){
	 filter -> cBi[0] = 1.0f;
	 filter -> cBi[1] = 0.0f;

	 filter -> PrevIn = 0.0f;
	 filter -> BiOut = 0.0f;
}

void DSP_IIR_LPF_SetCoeff(DSP_LPF *filter, float CutoffFreq, float SampleFreq){
	// normalized pre-warp Fc
	float wcT = 2.0f * tanf(M_pi * CutoffFreq / SampleFreq);

	// calculate coefficients
	filter -> cBi[0] = wcT / (wcT + 2.0f);
	filter -> cBi[1] = (2.0f - wcT) / (wcT + 2.0f);


}

