#include "UI/UI_Update.h"
#include "ssd1306_fonts.h"


void UI_SwitchStates(UI_state_t *state){
    switch(state -> active_page)
    {
        case UI_PAGE_INIT:
            state -> active_page = UI_PAGE_MAIN;
            break;

        case UI_PAGE_MAIN:
        	state -> selected_effect = state -> selected_param;
            state -> active_page = UI_PAGE_PARAMETER_SELECT;
            break;

        case UI_PAGE_PARAMETER_SELECT:
            if(state -> selected_param == 0) state -> active_page = UI_PAGE_EFFECT_SELECT;
            if(state -> selected_param == 1) state -> active_page = UI_PAGE_MAIN;
            if(state -> selected_param == 2) state -> active_page = UI_PAGE_VALUE_ENTRY;
            if(state -> selected_param == 3) state -> active_page = UI_PAGE_VALUE_ENTRY;
            if(state -> selected_param == 4) state -> active_page = UI_PAGE_VALUE_ENTRY;
            break;

        case UI_PAGE_VALUE_ENTRY:
        	break;

        case UI_PAGE_EFFECT_SELECT:
        	strncpy(state -> chosen_effect_labels[state -> selected_effect], state -> available_effect_labels[state -> selected_param], 16);
        	state -> active_page = UI_PAGE_PARAMETER_SELECT;
        	break;
        default:
            break;
    }
}


const unsigned char* UI_GetActiveBitmap(UI_page_t page){
    switch(page)
    {
        case UI_PAGE_INIT:
            return UI_Init_Screen;

        case UI_PAGE_MAIN:
            return UI_Main_Screen;

        case UI_PAGE_PARAMETER_SELECT:
        	return UI_BlankScreen;

        case UI_PAGE_EFFECT_SELECT:
            return UI_BlankScreen;

        default:
            return UI_BlankScreen;
    }
}

// updates selected_param based on encoder delta and active page
void UI_UpdateSelection(UI_state_t *state, int16_t delta){
    if(delta == 0) return;

    int8_t max_idx = 2; // default max index for 3 items
    switch(state->active_page){
        case UI_PAGE_MAIN:
            max_idx = 2; // 3 effects displayed
            break;
        case UI_PAGE_PARAMETER_SELECT:
            max_idx = 4; // 5 parameters
            break;
        case UI_PAGE_EFFECT_SELECT:
        	max_idx = 5; // 6 parameters
        	break;
        case UI_PAGE_VALUE_ENTRY:
        	break;
        default:
            max_idx = 0;
            break;
    }

    if(delta > 0) state->selected_param++;
    else state->selected_param--;

    // wraparound
    if(state->selected_param > max_idx) state->selected_param = 0;
    else if(state->selected_param < 0) state->selected_param = max_idx;
}


// function to update indicator on elected option
void UI_DrawSelectedOption(const UI_state_t *state){
    switch(state->active_page) {
        case UI_PAGE_MAIN: {
            int8_t sel = state->selected_param;
            ssd1306_FillCircle(24, 5 + (sel * 10), 2, White);
            break;
        }

        case UI_PAGE_PARAMETER_SELECT: {
            // Top effect label underline
            uint8_t sel = state->selected_param; // selected effect
            if(sel == 0){
            	uint8_t label_y = 8;  // under the text
            	uint8_t label_w = 6 * strlen(state->chosen_effect_labels[sel]);
            	ssd1306_Line(0, 8, label_w, label_y, White);
            }
            if (sel == 1){
            	ssd1306_Line(100, 8, 100 + 24, 8, White);
            } else {
            	// Bottom parameter underline
            	uint8_t param_y = 15;
            	uint8_t underline_y = param_y + 8;
            	for(uint8_t i = 0; i < 3; i++){
                	uint8_t x = START_X + i * (PARAM_W + PARAM_GAP);
                	if(i == sel - 2) // sel should now refer to selected param
                    	ssd1306_Line(x, underline_y, x + PARAM_W, underline_y, White);
            	}
            	break;
            }
        }

        default:
            break;
    }
}



// Function to update major screen elements
void UI_UpdateOLED(UI_state_t *state){
    ssd1306_DrawBitmap(0, 0, UI_GetActiveBitmap(state -> active_page), 128, 32, White);

	if (state -> active_page == UI_PAGE_MAIN){
		for (uint8_t i = 0; i < 3; i++) {
        	ssd1306_SetCursor(30, i * 10 + 2);
        	ssd1306_WriteString(state -> chosen_effect_labels[i], Font_6x8, White);
    	}
	}

    if (state -> active_page == UI_PAGE_PARAMETER_SELECT){
    	ssd1306_SetCursor(0, 0);
    	ssd1306_WriteString(state -> chosen_effect_labels[state -> selected_effect], Font_6x8, White);
    	ssd1306_SetCursor(100, 0);
    	ssd1306_WriteString("Exit", Font_6x8, White);
    	ssd1306_SetCursor(0, 15);
    	for (uint8_t i = 0; i < 3; i++) {
    		uint8_t x = START_X + i * (PARAM_W + PARAM_GAP);
    		ssd1306_SetCursor(x, 15);
        	ssd1306_WriteString(state -> parameter_val_labels[i], Font_6x8, White); // write parameter value hardcoded for now
    	}
    }

    if (state -> active_page == UI_PAGE_VALUE_ENTRY){
    	state -> current_parameter_pos = state -> selected_param; // store position of parameter user wishes to change
    	uint8_t percent = (uint32_t)(((uint64_t)state->cnt_curr * 100) / 0xFF);
    	char buf[6];
    	if(percent == 100) {
    	    strcpy(buf, "100");
    	} else {
    	    buf[0] = '0' + (percent / 10);
    	    buf[1] = '0' + (percent % 10);
    	    buf[2] = '\0';
    	}
    	state -> parameter_values[state -> current_parameter_pos] = percent;
    	strncpy(state -> parameter_val_labels[state -> selected_param], buf, 16);
    	ssd1306_SetCursor(31, 11);
    	ssd1306_WriteString(state -> parameter_val_labels[state -> selected_param], Font_6x8, White);
    }

    if (state -> active_page == UI_PAGE_EFFECT_SELECT){
    	ssd1306_Line(30, 25, 90, 25, White);
    	ssd1306_SetCursor(31, 11);
    	ssd1306_WriteString(state -> available_effect_labels[state -> selected_param], Font_6x8, White);
    }
}
